{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": ".test-dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/types.ts",
    "src/state/**/*.ts",
    "src/collectors/parsers.ts",
    "src/collectors/jsonlWatch.ts",
    "tests/**/*.ts"
  ]
}
